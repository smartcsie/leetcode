std::vector<int> getPrimeFactors(long long n) {
    std::vector<int> result;
    // 處理 2
    while (n % 2 == 0) {
        result.push_back(2);
        n /= 2;
    }
    // 處理奇數因子
    for (long long i = 3; i * i <= n; i += 2) {
        while (n % i == 0) {
            result.push_back(i);
            n /= i;
        }
    }
    // 處理剩下的質數
    if (n > 1) result.push_back(n); 
    return result;
}

void permute(vector<int>& nums, int start, vector<vector<int>>& res) {
        if(start == nums.size()) {
            res.emplace_back(nums);
        }
        for(int i = start; i < nums.size(); i++) {
            swap(nums[start], nums[i]);
            permute(nums, start + 1, res);
            swap(nums[start], nums[i]);
        }
    }

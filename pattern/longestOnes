class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int max_ones = 0;
        int ones = 0;
        for(int i = 0; i < nums.size(); i++ ) {
            if(nums[i] & 1) {
                if(i > 0 && !(nums[i - 1] & 1)) ones = 1;
                else ones++;
                max_ones = max(max_ones, ones);
            }
        }
        return max_ones;
    }
};
